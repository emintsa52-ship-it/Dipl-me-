    <header>
        <a href="#" class="logo" onclick="resetForm()">stu<span>di</span></a>
    </header>

    <main>
        <div class="container" id="mainContainer">
            
            <div id="searchSection">
                <h1>Vérification d'Attestation</h1>
                <div class="subtitle">Saisissez le numéro unique ou le nom complet de l'étudiant pour vérifier l'authenticité du document.</div>
                
                <div class="search-box">
                    <div class="input-wrapper">
                        <input type="text" id="searchInput" placeholder="Numéro unique ou Nom de l'étudiant" autocomplete="off">
                    </div>
                    <button onclick="verifyDocument()">Vérifier le document</button>
                </div>
                <div class="hint">
                    <strong>Options de test valides :</strong><br>
                    • ATTEST-STUDI-2026-0231<br>
                    • OWONO MINTSA Evrard Quentin
                </div>
            </div>

            <div class="loader" id="loader">
                <div class="spinner"></div>
                <div>Recherche dans le registre central de Studi...</div>
            </div>

            <div class="result-box" id="resultSection">
                <div style="text-align: center;">
                    <div class="status-badge">Document Officiel Vérifié</div>
                </div>
                
                <h2 style="font-size: 20px; text-align: center; margin-top: 0;">Attestation de Réussite Authentique</h2>
                <div class="subtitle" style="margin-bottom: 25px;">ID Vérification : ATTEST-STUDI-2026-0231</div>

                <div class="info-grid">
                    <div class="info-group full-width">
                        <div class="info-label">Titulaire</div>
                        <div class="info-value">OWONO MINTSA Evrard Quentin</div>
                    </div>

                    <div class="info-group full-width">
                        <div class="info-label">Diplôme / Certification</div>
                        <div class="info-value">MBA en Stratégie Digitale</div>
                    </div>

                    <div class="info-group">
                        <div class="info-label">Mention</div>
                        <div class="info-value highlight">Très bien avec félicitations du jury</div>
                    </div>

                    <div class="info-group">
                        <div class="info-label">Date d'obtention</div>
                        <div class="info-value">29 mars 2026</div>
                    </div>

                    <div class="info-group">
                        <div class="info-label">Encadreur Professionnel</div>
                        <div class="info-value">Yvon LEMARCHAL</div>
                    </div>

                    <div class="info-group">
                        <div class="info-label">Autorité de Délivrance</div>
                        <div class="info-value">Pierre Charvet (Directeur Général)</div>
                    </div>
                </div>

                <button class="btn-reset" onclick="resetForm()">Nouvelle vérification</button>

                <div class="footer-note">
                    Cet écran confirme que le document présenté est authentique et correspond exactement aux archives numériques de l'établissement STUDI France.
                </div>
            </div>

            <div class="error-box" id="errorSection">
                <div style="font-size: 40px; margin-bottom: 10px;">⚠️</div>
                <h3>Aucun document trouvé</h3>
                <p style="color: var(--text-muted); font-size: 14px;">La recherche ne correspond à aucun document archivé ou étudiant valide dans notre base de données.</p>
                <button class="btn-reset" onclick="resetForm()">Réessayer</button>
            </div>

        </div>
    </main>

    <footer>
        Siège social : 155 rue de Charonne, 75011 Paris, France | &copy; 2026 Studi - Tous droits réservés.
    </footer>

    <script>
        function verifyDocument() {
            // Nettoyage de la saisie (suppression des espaces superflus à la fin et passage en majuscules)
            const query = document.getElementById('searchInput').value.trim().toUpperCase();
            
            const validId = "ATTEST-STUDI-2026-0231";
            const validName = "OWONO MINTSA EVRARD QUENTIN";
            
            if (query === "") {
                alert("Veuillez saisir un numéro d'attestation ou un nom.");
                return;
            }

            // Masquer la recherche et afficher le chargement
            document.getElementById('searchSection').style.display = 'none';
            document.getElementById('loader').style.display = 'block';

            // Simuler un court délai de recherche réseau (1.2 seconde)
            setTimeout(() => {
                document.getElementById('loader').style.display = 'none';
                
                // Vérification si la saisie correspond à l'ID OU au Nom recherché
                if (query === validId || query === validName) {
                    document.getElementById('resultSection').style.display = 'block';
                    document.getElementById('mainContainer').style.borderTop = "none";
                } else {
                    document.getElementById('errorSection').style.display = 'block';
                    document.getElementById('mainContainer').style.borderTop = "none";
                }
            }, 1200);
        }

        function resetForm() {
            document.getElementById('searchInput').value = "";
            document.getElementById('resultSection').style.display = 'none';
            document.getElementById('errorSection').style.display = 'none';
            document.getElementById('loader').style.display = 'none';
            document.getElementById('searchSection').style.display = 'block';
        }

        // Permet de valider en appuyant sur "Entrée"
        document.getElementById('searchInput').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                verifyDocument();
            }
        });
    </script>
</body>
